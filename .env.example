# ============================================================
# THE LAWO HOMESTAY — Environment Variables
# Copy this file to .env.local for local dev
# Set all of these in Vercel → Project → Settings → Environment Variables
# ============================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://lawohomestay.com

# --- Database (MySQL) ---
# Recommended: Railway (railway.app) or Aiven (aiven.io)
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl={"rejectUnauthorized":true}

# --- NextAuth ---
# Generate: openssl rand -base64 32
NEXTAUTH_URL=https://lawohomestay.com
NEXTAUTH_SECRET=REPLACE_WITH_STRONG_SECRET

# --- Billplz ---
# From: https://www.billplz.com/enterprise/setting (API section)
BILLPLZ_API_KEY=your-billplz-api-key
BILLPLZ_COLLECTION_ID=fgb6ivod
# From: Billplz dashboard → Collection → X-Signature Key (SEPARATE from API key)
BILLPLZ_X_SIGNATURE_KEY=your-x-signature-key

# --- Meta Conversions API ---
# From: Meta Events Manager → Data Sources → your Pixel → Settings
META_PIXEL_ID=your-pixel-id
META_ACCESS_TOKEN=your-capi-access-token
# Optional — only for testing in Meta Test Events tool, remove in production
# META_TEST_EVENT_CODE=TEST12345

# --- Internal Security ---
# Protects /api/capi from external calls — generate: openssl rand -base64 32
INTERNAL_API_SECRET=REPLACE_WITH_STRONG_SECRET

# --- Google Tag Manager ---
# From: tagmanager.google.com → your container ID (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- iCal (Airbnb / Booking.com sync) ---
# From: Airbnb → Listing → Calendar → Export Calendar → copy the ical URL
# UNIT1_ICAL_URL=https://www.airbnb.com/calendar/ical/LISTING_ID.ics?s=TOKEN
# UNIT2_ICAL_URL=https://www.airbnb.com/calendar/ical/LISTING_ID.ics?s=TOKEN
